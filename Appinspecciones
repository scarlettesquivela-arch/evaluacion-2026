<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo de Listas - Clínica Alemana</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .custom-shadow { box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03); }
    </style>
</head>
<body class="bg-[#f8faff] pb-24">

    <header class="p-6 max-w-md mx-auto">
        <div class="flex justify-between items-center mb-6">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-[#134e4a] rounded-lg flex items-center justify-center">
                    <svg class="text-white w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span class="font-bold text-slate-800">Clínica Alemana</span>
            </div>
            <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/></svg>
            </div>
        </div>

        <h1 class="text-3xl font-bold text-slate-900 mb-2">Catálogo de Listas.</h1>
        <p class="text-gray-500 leading-tight mb-6">
            Protocolos de seguridad clínica y estándares hospitalarios. Seleccione un módulo para iniciar la auditoría.
        </p>

        <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-width="2"/></svg>
            </span>
            <input 
                type="text" 
                id="searchInput"
                placeholder="Buscar módulos (ej: 'Quirófano')" 
                class="w-full p-4 pl-10 bg-white border border-gray-100 rounded-2xl shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all"
            >
        </div>
    </header>

    <main id="modulesContainer" class="px-6 max-w-md mx-auto space-y-4">
        
        <div class="module-card bg-white p-6 rounded-[2rem] border border-gray-50 custom-shadow" data-title="seguridad en quirofano">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-slate-50 text-teal-600 rounded-xl">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke-width="2"/></svg>
                </div>
                <span class="bg-red-600 text-white text-[10px] font-bold px-2 py-1 rounded-full">PRIORIDAD ALTA</span>
            </div>
            <h3 class="text-xl font-bold mb-1">Seguridad en Quirófano</h3>
            <p class="text-sm text-gray-500 mb-4">Protocolos de verificación pre-quirúrgica, conteo de instrumental y seguridad anestésica.</p>
            <div class="flex justify-between items-center">
                <div class="flex gap-4">
                    <div><p class="text-[10px] text-gray-400">ITEMS</p><p class="font-bold text-sm">32 Puntos</p></div>
                    <div><p class="text-[10px] text-gray-400">TIEMPO</p><p class="font-bold text-sm">20 Min</p></div>
                </div>
                <button class="bg-teal-800 text-white p-2 rounded-full">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2"/></svg>
                </button>
            </div>
        </div>

        <div class="module-card bg-[#0f1d27] p-6 rounded-[2rem] text-white" data-title="control de infecciones iaas">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-teal-900/30 text-teal-400 rounded-xl">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z" stroke-width="2"/></svg>
                </div>
            </div>
            <h3 class="text-xl font-bold mb-1">Control de Infecciones IAAS</h3>
            <p class="text-sm text-gray-400 mb-4">Vigilancia de higiene de manos y esterilización.</p>
            <div class="mb-4">
                <div class="flex justify-between text-[10px] mb-1">
                    <span>CUMPLIMIENTO GLOBAL</span>
                    <span class="font-bold">96%</span>
                </div>
                <div class="w-full bg-gray-700 h-1 rounded-full">
                    <div class="bg-teal-500 h-1 rounded-full" style="width: 96%"></div>
                </div>
            </div>
            <div class="flex justify-between items-center">
                <div class="flex gap-4 text-xs font-bold">
                    <span>55 Preguntas</span>
                    <span>10 Min</span>
                </div>
                <button class="border border-gray-600 p-2 rounded-lg">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2"/></svg>
                </button>
            </div>
        </div>

        <div id="statsCard" class="bg-[#0f1d27] p-8 rounded-[2rem] text-white text-center mt-6">
            <p class="text-[10px] text-teal-500 font-bold mb-2">ESTADO DEL SISTEMA</p>
            <h2 class="text-2xl font-bold mb-4">Integridad Clínica</h2>
            <div class="flex justify-around border-t border-gray-800 pt-6">
                <div><p class="text-4xl font-bold">62</p><p class="text-gray-500 text-[10px]">MÓDULOS</p></div>
                <div><p class="text-4xl font-bold text-teal-400">1.8k</p><p class="text-gray-500 text-[10px]">AUDITORÍAS</p></div>
            </div>
        </div>
    </main>

    <nav class="fixed bottom-0 left-0 right-0 bg-white/90 backdrop-blur-md border-t border-gray-100 p-4">
        <div class="flex justify-around items-center max-w-md mx-auto">
            <div class="flex flex-col items-center text-gray-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-width="2"/></svg>
                <span class="text-[10px]">Inicio</span>
            </div>
            <div class="flex flex-col items-center text-teal-600 font-bold">
                <div class="bg-teal-50 p-2 rounded-xl mb-1">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-width="2"/></svg>
                </div>
                <span class="text-[10px]">LISTAS</span>
            </div>
            <div class="flex flex-col items-center text-gray-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-width="2"/></svg>
                <span class="text-[10px]">Reportes</span>
            </div>
        </div>
    </nav>

    <script>
        const searchInput = document.getElementById('searchInput');
        const cards = document.querySelectorAll('.module-card');
        const statsCard = document.getElementById('statsCard');

        searchInput.addEventListener('input', (e) => {
            const text = e.target.value.toLowerCase();
            
            cards.forEach(card => {
                const title = card.getAttribute('data-title');
                if (title.includes(text)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });

            // Ocultar estadísticas si hay búsqueda activa
            statsCard.style.display = text.length > 0 ? 'none' : 'block';
        });
    </script>
</body>
</html>
