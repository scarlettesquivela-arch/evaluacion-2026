<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Inspecciones SSO</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans text-gray-800 h-screen overflow-hidden flex">

    <aside id="sidebar" class="bg-gray-800 text-white w-64 flex-shrink-0 transition-all duration-300">
        <div class="p-4 flex justify-between items-center bg-gray-900">
            <h1 class="text-xl font-bold">SSO Salud</h1>
            <button id="btn-toggle-sidebar" class="text-gray-400 hover:text-white">☰</button>
        </div>
        
        <nav class="mt-5">
            <p class="px-4 text-xs text-gray-400 uppercase tracking-wider mb-2">Menú Principal</p>
            
            <div id="menu-dashboard">
                <a href="#" class="block px-4 py-2 hover:bg-gray-700">📊 Dashboard General</a>
            </div>
            <div id="menu-carga">
                <a href="#" class="block px-4 py-2 hover:bg-gray-700">📋 Carga de Listas</a>
            </div>
            
            <div id="menu-inspeccion" class="hidden">
                <a href="#" class="block px-4 py-2 hover:bg-gray-700">🔍 Nueva Inspección</a>
            </div>
        </nav>
    </aside>

    <main class="flex-1 flex flex-col bg-gray-100">
        <header class="bg-white shadow p-4 flex justify-between items-center">
            <h2 class="text-lg font-semibold" id="vista-actual-titulo">Inicio</h2>
            
            <div class="flex items-center gap-4 border p-2 rounded bg-gray-50">
                <label for="simulador-rol" class="text-sm font-bold text-gray-600">Simular vista como:</label>
                <select id="simulador-rol" class="bg-white border text-sm rounded px-2 py-1 outline-none focus:border-blue-500">
                    <option value="Administrador">Administrador</option>
                    <option value="Evaluador">Evaluador</option>
                </select>
            </div>
        </header>
        
        <div class="p-6 overflow-y-auto h-full" id="contenido-principal">
            <div class="bg-white p-6 rounded shadow border-l-4 border-blue-500">
                <h3 class="text-xl font-bold mb-2">¡Layout Base Listo!</h3>
                <p class="text-gray-600">Hemos omitido el inicio de sesión. Utiliza el menú superior derecho para simular cómo cambia el menú lateral según el perfil.</p>
            </div>
        </div>
    </main>

    <script>
        // Referencias a los elementos del menú
        const menuDashboard = document.getElementById('menu-dashboard');
        const menuCarga = document.getElementById('menu-carga');
        const menuInspeccion = document.getElementById('menu-inspeccion');

        // Función para cambiar la vista según el rol seleccionado
        function actualizarMenuPorRol(rol) {
            if (rol === 'Administrador') {
                menuDashboard.classList.remove('hidden');
                menuCarga.classList.remove('hidden');
                menuInspeccion.classList.add('hidden'); 
            } else if (rol === 'Evaluador') {
                menuDashboard.classList.add('hidden');
                menuCarga.classList.add('hidden');
                menuInspeccion.classList.remove('hidden');
            }
        }

        // Escuchar el cambio en el selector de roles
        document.getElementById('simulador-rol').addEventListener('change', (evento) => {
            actualizarMenuPorRol(evento.target.value);
        });

        // Utilidad: Colapsar/Expandir Panel Lateral
        document.getElementById('btn-toggle-sidebar').addEventListener('click', () => {
            const sidebar = document.getElementById('sidebar');
            if (sidebar.classList.contains('w-64')) {
                sidebar.classList.replace('w-64', 'w-16');
            } else {
                sidebar.classList.replace('w-16', 'w-64');
            }
        });
    </script>
</body>
</html>
