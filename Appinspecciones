<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Motor de Inspecciones CAS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>
<body class="bg-gray-50 flex h-screen overflow-hidden text-gray-800">

    <aside class="w-72 bg-slate-800 text-white flex flex-col shadow-lg z-20">
        <div class="p-5 bg-slate-900 border-b border-slate-700">
            <h1 class="text-xl font-bold">Inspecciones CAS</h1>
            <p id="texto-rol" class="text-xs text-green-400 mt-1 font-semibold">Perfil: Administrador</p>
        </div>
        
        <nav id="sidebar-menu" class="flex-1 overflow-y-auto p-3 space-y-1">
            </nav>
        
        <div id="contenedor-btn-admin" class="p-4 bg-slate-900 border-t border-slate-700">
            <button onclick="toggleAdminPanel()" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold py-3 px-4 rounded transition shadow-lg">
                ⚙️ Cargar Nueva Lista
            </button>
        </div>
    </aside>

    <main class="flex-1 flex flex-col overflow-hidden relative">
        <header class="bg-white shadow-sm border-b px-6 py-4 flex justify-between items-center z-10">
            <h2 id="titulo-lista" class="text-2xl font-semibold text-gray-700">Seleccione una inspección</h2>
            
            <div class="flex items-center gap-4">
                <div class="bg-gray-200 p-1 rounded-lg flex text-sm font-semibold">
                    <button onclick="cambiarRol('Evaluador')" id="btn-evaluador" class="px-4 py-1.5 rounded text-gray-600 hover:bg-gray-300 transition">Evaluador</button>
                    <button onclick="cambiarRol('Administrador')" id="btn-admin" class="px-4 py-1.5 rounded bg-white text-blue-700 shadow transition">Administrador</button>
                </div>

                <button onclick="abrirModalInforme()" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded shadow transition">
                    📄 Informe Flash
                </button>
            </div>
        </header>
        
        <div id="contenedor-preguntas" class="flex-1 overflow-y-auto p-6 bg-gray-50">
            <div class="flex items-center justify-center h-full text-gray-400">
                <p>Las preguntas de la lista aparecerán aquí.</p>
            </div>
        </div>

        <div id="admin-panel" class="hidden absolute inset-0 bg-slate-100 z-50 flex flex-col p-8 overflow-y-auto">
            <div class="flex justify-between items-center mb-6 bg-white p-4 rounded shadow">
                <h2 class="text-2xl font-bold text-gray-800">⚙️ Carga Masiva de Listas (CSV)</h2>
                <button onclick="toggleAdminPanel()" class="text-gray-500 hover:text-red-600 text-4xl font-bold transition">&times;</button>
            </div>
            
            <div class="bg-white shadow border border-gray-200 rounded-lg p-6 max-w-3xl">
                <div class="flex flex-col gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Categoría de la Inspección</label>
                        <select id="categoria-nueva-lista" class="w-full p-2 border border-gray-300 rounded bg-white outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="LV- Inspección DGR">1. LV- Inspección DGR</option>
                            <option value="Seguridad de las instalaciones">2. Seguridad de las instalaciones</option>
                            <option value="Riesgo de emergencias">3. Riesgo de emergencias</option>
                            <option value="Gestión de riesgo SST">4. Gestión de riesgo SST</option>
                            <option value="Sustancias peligrosas">5. Sustancias peligrosas</option>
                            <option value="Gestión de residuos">6. Gestión de residuos</option>
                            <option value="Equipamiento Médico">7. Equipamiento Médico</option>
                            <option value="Unidades Especificas">8. Unidades Específicas</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre de la Lista (Ej: Timbres de Paro)</label>
                        <input type="text" id="nombre-nueva-lista" class="w-full p-2 border rounded outline-none focus:ring-2 focus:ring-blue-500" placeholder="Escribe el nombre aquí...">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Archivo CSV (UTF-8 o ISO-8859-1)</label>
                        <input type="file" id="csv-file" accept=".csv" class="w-full p-2 border rounded bg-gray-50">
                    </div>
                    
                    <button onclick="procesarCSV()" class="mt-2 bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded shadow transition">
                        Procesar y Agregar a Categoría
                    </button>
                </div>
            </div>
            <pre id="consola-salida" class="mt-6 bg-slate-900 text-green-400 p-4 rounded-lg text-xs overflow-x-auto h-48 shadow-inner">Esperando archivo...</pre>
        </div>

        <div id="modal-informe" class="hidden absolute inset-0 bg-gray-200 z-50 flex flex-col p-4 overflow-y-auto">
            <div class="max-w-4xl mx-auto w-full">
                <div class="flex justify-between items-center mb-4 sticky top-0 bg-gray-200 py-2 z-10">
                    <button onclick="cerrarModalInforme()" class="bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded">Volver a la Inspección</button>
                    <button onclick="exportarPDF()" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded font-bold shadow-lg">💾 Exportar a PDF</button>
                </div>
                <div id="documento-pdf" class="bg-white p-10 shadow-2xl rounded-lg text-gray-800 text-sm">
                    <div class="border-b-2 border-red-700 pb-4 mb-6 flex justify-between items-end">
                        <div>
                            <h1 class="text-2xl font-extrabold text-red-700">INFORME FLASH DE INSPECCIÓN</h1>
                            <p class="text-gray-500 font-semibold mt-1">Departamento de Gestión de Riesgos (DGR)</p>
                        </div>
                        <div class="text-right text-xs text-gray-500">Fecha de Emisión: <span id="fecha-emision"></span></div>
                    </div>
                    <h2 class="bg-gray-100 p-2 font-bold mb-3 border-l-4 border-red-600 uppercase">1. Antecedentes de la Inspección</h2>
                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div><label class="font-bold text-xs">Instalación:</label> <input type="text" class="border-b w-full outline-none py-1" value="Clínica Alemana Santiago"></div>
                        <div><label class="font-bold text-xs">Unidad o Servicio:</label> <input type="text" class="border-b w-full outline-none py-1"></div>
                        <div><label class="font-bold text-xs">Nombre del Evaluador:</label> <input type="text" class="border-b w-full outline-none py-1"></div>
                        <div><label class="font-bold text-xs">Líder del Servicio:</label> <input type="text" class="border-b w-full outline-none py-1"></div>
                    </div>
                    <h2 class="bg-gray-100 p-2 font-bold mb-3 border-l-4 border-red-600 uppercase">2. Reconocimiento Preventivo</h2>
                    <div class="mb-6"><textarea class="w-full border p-2 rounded outline-none resize-none" rows="3" placeholder="Destacar una buena práctica observada..."></textarea></div>
                    <h2 class="bg-gray-100 p-2 font-bold mb-3 border-l-4 border-red-600 uppercase">3. Hallazgos Críticos y Plan de Acción (PAC)</h2>
                    <div id="tabla-hallazgos-container"></div>
                    <div class="flex justify-between items-end mt-16 px-10">
                        <div class="text-center w-1/3"><div class="border-t border-gray-400 pt-2 font-bold">Firma Evaluador DGR</div></div>
                        <div class="text-center w-1/3"><div class="border-t border-gray-400 pt-2 font-bold">Firma Líder del Servicio</div></div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="app.js"></script>
</body>
</html>
